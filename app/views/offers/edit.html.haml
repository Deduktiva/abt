= page_header("Edit offer #{@offer.document_number || "Draft \##{@offer.id}"}")

= simple_form_for(@offer, url: offer_path(@offer), method: :patch, validation: true, html: { class: 'form-horizontal' }) do |f|
  - if @offer.errors.any?
    .alert.alert-danger
      %h4 #{pluralize(@offer.errors.count, 'error')} prohibited saving:
      %ul
        - @offer.errors.full_messages.each do |msg|
          %li= msg

  .row.mb-3
    = f.label :matchcode, label: 'Slug', class: 'col-lg-2 col-md-3 col-form-label'
    .col-md-5
      = f.text_field :matchcode, class: 'form-control', required: true

  .row.mb-3
    %label.col-lg-2.col-md-3.col-form-label Customer
    .col-md-5
      %div{ data: {
          controller: 'searchable-dropdown',
          searchable_dropdown_current_item_id_value: @offer.customer_id,
          searchable_dropdown_url_value: customers_path,
          searchable_dropdown_item_name_value: 'customer',
          searchable_dropdown_item_id_param_value: 'customer_id',
          searchable_dropdown_select_prompt_value: 'Select customer...'
        } }
        = f.hidden_field :customer_id, id: 'offer_customer_id'
        .dropdown.searchable-dropdown.customer-dropdown
          %button.btn.btn-outline-secondary.form-control.text-start.d-flex.justify-content-between.align-items-center{ type: 'button', data: { searchable_dropdown_target: 'select' } }
            .select-display
              - if @offer.customer
                .fw-normal= @offer.customer.name
                .small.text-muted= @offer.customer.matchcode
              - else
                %span.text-muted Select customer...
            %span.text-muted ▼
          .dropdown-menu{ id: 'customer-dropdown-menu', data: { searchable_dropdown_target: 'dropdown' } }
            .p-2.border-bottom
              %input.form-control.form-control-sm{ type: 'text', placeholder: 'Search customers...', data: { searchable_dropdown_target: 'search' } }
            .dropdown-content
              .dropdown-item.text-muted Loading...

  .row.mb-3
    %label.col-lg-2.col-md-3.col-form-label Project
    .col-md-5
      %div{ data: {
          controller: 'searchable-dropdown',
          searchable_dropdown_current_dependent_id_value: @offer.customer_id,
          searchable_dropdown_current_item_id_value: @offer.project_id,
          searchable_dropdown_url_value: projects_path,
          searchable_dropdown_dependent_param_value: 'customer_id',
          searchable_dropdown_item_name_value: 'project',
          searchable_dropdown_item_id_param_value: 'project_id',
          searchable_dropdown_select_prompt_value: 'Select project...',
          searchable_dropdown_dependent_select_prompt_value: 'Select customer first...',
          searchable_dropdown_dependent_field_selector_value: '#offer_customer_id'
        } }
        = f.hidden_field :project_id
        .dropdown.searchable-dropdown.project-dropdown
          %button.btn.btn-outline-secondary.form-control.text-start.d-flex.justify-content-between.align-items-center{ type: 'button', data: { searchable_dropdown_target: 'select' } }
            .select-display
              - if @offer.project && @offer.project.id
                .fw-normal= @offer.project.display_name
                .small.text-muted= @offer.project.matchcode
              - else
                %span.text-muted Select project...
            %span.text-muted ▼
          .dropdown-menu{ id: 'project-dropdown-menu', data: { searchable_dropdown_target: 'dropdown' } }
            .p-2.border-bottom
              %input.form-control.form-control-sm{ type: 'text', placeholder: 'Search projects...', data: { searchable_dropdown_target: 'search' } }
            .dropdown-content
              .dropdown-item.text-muted Loading...

  .row.mb-3
    = f.label :addressed_to_contact_id, label: 'Addressed to', class: 'col-lg-2 col-md-3 col-form-label'
    .col-md-5
      = f.collection_select :addressed_to_contact_id,
                            @offer.customer.customer_contacts.order(:name),
                            :id, :name,
                            { prompt: 'Select contact...' }, class: 'form-select'
      .form-text The salutation set on this contact is used to personalize the offer.

  = fields_for "offer[version]", @version do |vf|
    .row.mb-3
      = vf.label :prelude, label: 'Prelude', class: 'col-lg-2 col-md-3 col-form-label'
      .col-md-10
        = vf.text_area :prelude, class: 'form-control', rows: 10
        .form-text Long-form description of the work, rendered before the milestones.

    .row.mb-3
      = vf.label :delivery_start_date, label: 'Delivery start', class: 'col-lg-2 col-md-3 col-form-label'
      .col-md-3
        = vf.date_field :delivery_start_date, class: 'form-control'
      = vf.label :delivery_end_date, label: 'Delivery end', class: 'col-lg-2 col-form-label'
      .col-md-3
        = vf.date_field :delivery_end_date, class: 'form-control'

    .row.mb-3
      = vf.label :sales_tax_product_class_id, label: 'Tax class', class: 'col-lg-2 col-md-3 col-form-label'
      .col-md-5
        = vf.collection_select :sales_tax_product_class_id,
                               SalesTaxProductClass.all.order(:name),
                               :id, :name,
                               { prompt: 'Select tax class...' }, class: 'form-select'

    .row.mb-3
      = vf.label :salutation_override, label: 'Salutation override', class: 'col-lg-2 col-md-3 col-form-label'
      .col-md-5
        = vf.text_field :salutation_override, class: 'form-control'
        .form-text If blank, the addressed contact's salutation is used.

    .row.mb-3
      = vf.label :client_line_override, label: 'Client line override', class: 'col-lg-2 col-md-3 col-form-label'
      .col-md-5
        = vf.text_field :client_line_override, class: 'form-control'
        .form-text If blank, the line is composed from customer + project department.

  = action_buttons_wrapper do
    = f.submit 'Save', class: 'btn btn-primary'
    = cancel_button(@offer)

%hr.mt-4

%h4 Milestones (v#{@version.version_number})

- if @version.offer_milestones.none? && @offer.customer.offer_milestone_rule_configured?
  .card.bg-light.mb-3
    .card-body
      %h5.card-title Apply customer rule
      %p.small.mb-2
        Customer's milestone rule splits at
        %strong= format_currency(@offer.customer.offer_milestone_split_threshold)
        \. First-milestone ratio:
        %strong= @offer.customer.offer_milestone_split_first_ratio
        \.
      = form_with url: scaffold_offer_milestones_path(@offer), method: :post, local: true, class: 'row gx-2 align-items-end' do |sf|
        .col-md-4
          %label.form-label.small Total amount
          = sf.number_field :total_amount, step: 0.01, min: 0, class: 'form-control form-control-sm', required: true
        .col-md-3
          = sf.submit 'Scaffold milestones', class: 'btn btn-sm btn-secondary'

- @version.offer_milestones.order(:position, :id).each do |m|
  = render 'milestone_row', offer: @offer, milestone: m

= render 'milestone_row', offer: @offer, milestone: @version.offer_milestones.build(net_amount: 0)
