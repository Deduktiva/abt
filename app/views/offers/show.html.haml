= page_header("Offer #{@offer.document_number || "Draft \##{@offer.id}"}")

.row.mb-3
  .col-md-8
    %dl.row
      %dt.col-sm-3 Slug
      %dd.col-sm-9= @offer.matchcode

      %dt.col-sm-3 Customer
      %dd.col-sm-9= @offer.customer.name

      - if @offer.project
        %dt.col-sm-3 Project
        %dd.col-sm-9= @offer.project.matchcode

      %dt.col-sm-3 State
      %dd.col-sm-9
        %span.badge{class: case @offer.state
                          when "accepted" then "bg-success"
                          when "sent" then "bg-warning"
                          when "rejected" then "bg-danger"
                          when "expired" then "bg-dark"
                          else "bg-secondary"
                          end}
          = @offer.state.titleize

      - if @offer.expires_at
        %dt.col-sm-3 Expires
        %dd.col-sm-9= l(@offer.expires_at.to_date)

      - if @offer.accepted_at
        %dt.col-sm-3 Accepted
        %dd.col-sm-9
          = l(@offer.accepted_at.to_date)
          %small.text-muted
            (v#{@offer.accepted_version&.version_number})

  .col-md-4.text-end
    - can_edit_offer = can?('offers.edit')
    = action_buttons_wrapper do
      = action_button 'Back', offers_path, :secondary
      - if @offer.state_draft? && can_edit_offer
        = action_button 'Edit', edit_offer_path(@offer), :primary
        = button_to 'Send', send_offer_path(@offer), method: :post, class: 'btn btn-warning',
                    data: { turbo_confirm: 'Send this offer to the customer?' },
                    disabled: !(@offer.current_version&.offer_milestones&.any?)
        = destroy_link(@offer, "Delete this draft offer?")
      - if @offer.state_sent? && can_edit_offer
        = button_to 'Accept', accept_offer_path(@offer), method: :post, class: 'btn btn-success',
                    data: { turbo_confirm: 'Mark this offer as accepted by the customer?' }
        = button_to 'Reject', reject_offer_path(@offer), method: :post, class: 'btn btn-outline-danger',
                    data: { turbo_confirm: 'Mark this offer as rejected?' }
      - if @offer.state_accepted? && can_edit_offer
        = button_to 'Reopen', reopen_offer_path(@offer), method: :post, class: 'btn btn-outline-warning',
                    data: { turbo_confirm: 'Reopen accepted offer for further edits?' }

- if @current_version
  .card.mt-3
    .card-header
      %strong Current version
      \—
      v#{@current_version.version_number}
      \—
      %span.badge{class: @current_version.state_draft? ? "bg-secondary" : "bg-warning"}
        = @current_version.state.titleize
    .card-body
      - if @current_version.offer_milestones.any?
        %table.table.table-sm.mb-0
          %tr
            %th Position
            %th Title
            %th Trigger
            %th Net amount
            - if @offer.state_accepted?
              %th Conversion
          - @current_version.offer_milestones.each do |m|
            %tr
              %td= m.position
              %td
                = m.title
                - if m.converted?
                  %span.badge.bg-success.ms-1 Converted
              %td= m.trigger.humanize
              %td= format_currency(m.net_amount)
              - if @offer.state_accepted?
                %td
                  - if m.invoice_id
                    Invoice
                    = link_to(m.invoice.document_number || "##{m.invoice_id}", invoice_path(m.invoice_id))
                    - if m.delivery_note_id
                      , DN
                      = link_to(m.delivery_note.document_number || "##{m.delivery_note_id}", delivery_note_path(m.delivery_note_id))
                    - if can?('offers.convert')
                      = button_to 'Unlink', reopen_offer_milestone_path(@offer, m), method: :post,
                                  class: 'btn btn-sm btn-outline-warning',
                                  data: { turbo_confirm: 'Unlink the converted invoice/DN from this milestone? Lets you convert again.' }
                  - elsif can?('offers.convert')
                    = button_to "Convert (skip DN)", convert_offer_milestone_path(@offer, m, skip_delivery_note: true), method: :post, class: 'btn btn-sm btn-outline-primary me-1'
                    = button_to "Convert (with DN)", convert_offer_milestone_path(@offer, m, skip_delivery_note: false), method: :post, class: 'btn btn-sm btn-primary'
      - else
        %p.text-muted.mb-0 No milestones yet.

- if @sent_versions.any?
  .card.mt-3
    .card-header
      %strong Past versions
    %ul.list-group.list-group-flush
      - @sent_versions.each do |v|
        %li.list-group-item
          v#{v.version_number}
          %span.badge.bg-light.text-dark.ms-2= v.state.titleize
          - if v.sent_at
            %small.text-muted.ms-2 sent #{l(v.sent_at.to_date)}
