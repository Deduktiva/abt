- content_for :title, 'Invites'

= breadcrumbs 'Configuration', ['Users', users_path], 'Invites', action: button_to('+ New', user_invites_path, method: :post, class: 'btn btn-primary', data: { turbo: false })

%table.table.table-striped.table-hover.table-sm
  %thead
    %tr
      %th Created
      %th Created by
      %th Expires
      %th Used
      %th Used by
  %tbody
    - @invites.each do |invite|
      %tr
        %td= l(invite.created_at)
        %td= invite.created_by_user&.username || 'system'
        %td= l(invite.expires_at)
        %td
          - if invite.used_at
            %span.badge.bg-success Used
            = l(invite.used_at)
          - elsif invite.expires_at <= Time.current
            %span.badge.bg-secondary Expired
          - else
            %span.badge.bg-warning Pending
        %td= invite.used_by_user&.username || '—'
