- content_for :title, 'Invite generated'

= breadcrumbs ['Configuration', configuration_path], ['Users', users_path], ['Invites', user_invites_path], 'Generated'
= page_header('Invite generated')

.alert.alert-info
  This URL is shown only once. Copy it now and share it with the invitee.

.card.mb-3
  .card-body
    %p.mb-1.text-muted Invite URL (valid until #{l(@invite.expires_at)}):
    %pre.mb-0
      %code= @invite_url

= action_buttons_wrapper do
  = button_to 'Generate another', user_invites_path, method: :post, class: 'btn btn-primary', data: { turbo: false }
